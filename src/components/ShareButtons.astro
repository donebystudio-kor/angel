---
interface Props {
  title: string;
  url: string;
}
const { title, url } = Astro.props;
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(url);
---

<div class="flex items-center gap-2 mt-6">
  <span class="text-sm text-angel-muted">공유하기:</span>
  <a
    href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`}
    target="_blank"
    rel="noopener noreferrer"
    class="px-3 py-1.5 bg-angel-border rounded-full text-xs text-angel-text hover:bg-angel-secondary hover:text-white transition-colors"
  >
    X
  </a>
  <a
    href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`}
    target="_blank"
    rel="noopener noreferrer"
    class="px-3 py-1.5 bg-angel-border rounded-full text-xs text-angel-text hover:bg-blue-600 hover:text-white transition-colors"
  >
    Facebook
  </a>
  <button
    onclick={`navigator.clipboard.writeText('${url}').then(()=>alert('링크가 복사되었습니다!'))`}
    class="px-3 py-1.5 bg-angel-border rounded-full text-xs text-angel-text hover:bg-angel-primary hover:text-white transition-colors cursor-pointer"
  >
    링크 복사
  </button>
</div>
