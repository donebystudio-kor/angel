---
import Layout from "../layouts/Layout.astro";
import SearchBar from "../components/SearchBar.astro";
import { ANGEL_NUMBERS, CATEGORY_LABELS } from "../data/angels";
import { TOPICS } from "../data/topics";
import type { Category } from "../data/angels";

const title = "엔젤넘버 해석 가이드 - 천사가 보내는 숫자 메시지";
const description = "111, 222, 333, 444, 555 등 엔젤넘버의 의미를 알아보세요. 천사들이 숫자를 통해 전하는 메시지를 한국어로 쉽게 해석해드립니다.";

const popular = ANGEL_NUMBERS.filter((a) =>
  ["111", "222", "333", "444", "555", "666", "777", "888", "999", "1111", "1212", "1010"].includes(a.number)
);

const grouped = ANGEL_NUMBERS.reduce(
  (acc, a) => {
    const cat = a.category as Category;
    if (!acc[cat]) acc[cat] = [];
    acc[cat].push(a);
    return acc;
  },
  {} as Record<Category, typeof ANGEL_NUMBERS>
);

const categoryOrder: Category[] = ["single", "repeat", "mirror", "sequence", "time", "double", "mixed"];

const guides = [
  { slug: "what-is-angel-number", title: "엔젤넘버란 무엇인가?", emoji: "👼", desc: "수비학적 배경과 원리를 알아보세요" },
  { slug: "how-to-find-angel-number", title: "나만의 엔젤넘버 찾는 법", emoji: "🔍", desc: "생년월일, 일상 패턴으로 찾기" },
  { slug: "angel-number-and-love", title: "엔젤넘버와 사랑", emoji: "💕", desc: "연애운과 인연의 숫자 신호" },
];

const faqItems = [
  { q: "엔젤넘버란 무엇인가요?", a: "엔젤넘버는 천사들이 숫자를 통해 보내는 메시지입니다. 시계, 영수증, 차량번호판 등 일상에서 반복적으로 같은 숫자를 보게 된다면, 그것은 우연이 아닌 우주의 신호일 수 있습니다." },
  { q: "엔젤넘버를 자주 보는 이유는 뭔가요?", a: "특정 숫자가 반복적으로 눈에 띈다면, 천사들이 당신에게 전하고 싶은 메시지가 있기 때문입니다. 삶의 전환기나 중요한 결정을 앞두고 있을 때 특히 자주 나타납니다." },
  { q: "엔젤넘버를 보면 어떻게 해야 하나요?", a: "먼저 그 순간 자신의 생각과 감정을 돌아보세요. 엔젤넘버는 그때의 상황과 연결된 메시지를 담고 있습니다. 해당 숫자의 의미를 참고하여 자신의 상황에 맞게 해석하면 됩니다." },
  { q: "엔젤넘버의 해석은 정확한 건가요?", a: "엔젤넘버 해석은 수비학과 영적 전통에 기반한 것으로, 절대적인 예언이 아닌 삶의 방향성을 제시하는 가이드입니다. 가장 중요한 것은 숫자를 볼 때 자신이 느끼는 직관적 감각입니다." },
];
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: faqItems.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a },
      })),
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="relative py-20 px-4 text-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-angel-secondary/10 via-angel-bg to-angel-bg"></div>
    <div class="relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold text-angel-text mb-4">
        👼 엔젤넘버 가이드
      </h1>
      <p class="text-angel-muted max-w-xl mx-auto text-lg mb-8">
        천사들이 숫자를 통해 전하는 메시지를 확인하세요.<br />
        반복적으로 보이는 숫자에는 특별한 의미가 담겨 있습니다.
      </p>
      <SearchBar />
    </div>
  </section>

  <!-- 인기 엔젤넘버 -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-angel-text mb-6">✨ 인기 엔젤넘버</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {popular.map((a) => (
        <a
          href={`/number/${a.number}`}
          class="bg-angel-card border border-angel-border rounded-2xl p-5 hover:shadow-lg hover:shadow-angel-glow hover:border-angel-primary/40 transition-all group"
        >
          <div class="text-2xl font-bold text-angel-accent group-hover:text-angel-primary transition-colors">
            {a.number}
          </div>
          <div class="text-sm text-angel-muted mt-1 line-clamp-2">{a.summary}</div>
        </a>
      ))}
    </div>
  </section>

  <!-- 주제별 카테고리 -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <h2 class="text-2xl font-bold text-angel-text mb-6">🎯 주제별 탐색</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {TOPICS.map((t) => (
        <a href={`/category/${t.slug}`} class="bg-angel-card border border-angel-border rounded-2xl p-5 text-center hover:border-angel-primary/50 hover:shadow-lg hover:shadow-angel-glow transition-all group">
          <div class="text-3xl mb-2">{t.emoji}</div>
          <div class="font-semibold text-angel-text group-hover:text-angel-primary transition-colors text-sm">{t.name}</div>
        </a>
      ))}
    </div>
  </section>

  <!-- 가이드 -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <h2 class="text-2xl font-bold text-angel-text mb-6">📖 엔젤넘버 가이드</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {guides.map((g) => (
        <a href={`/guide/${g.slug}`} class="bg-angel-card border border-angel-border rounded-2xl p-5 hover:border-angel-primary/50 hover:shadow-lg hover:shadow-angel-glow transition-all group">
          <div class="text-2xl mb-2">{g.emoji}</div>
          <h3 class="font-semibold text-angel-text group-hover:text-angel-primary transition-colors text-sm mb-1">{g.title}</h3>
          <p class="text-xs text-angel-muted">{g.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- 카테고리별 전체 목록 -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <h2 class="text-2xl font-bold text-angel-text mb-6">📂 전체 엔젤넘버</h2>
    {categoryOrder.map((cat) => (
      <div class="mb-8">
        <h3 class="text-lg font-semibold text-angel-accent mb-3">
          <a href={`/category/type/${cat}`} class="hover:text-angel-primary transition-colors">
            {CATEGORY_LABELS[cat]} →
          </a>
        </h3>
        <div class="flex flex-wrap gap-2">
          {grouped[cat]?.map((a) => (
            <a
              href={`/number/${a.number}`}
              class="px-3 py-1.5 bg-angel-card border border-angel-border rounded-full text-sm text-angel-text hover:bg-angel-primary hover:text-white transition-colors"
            >
              {a.number}
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>

  <!-- FAQ -->
  <section class="max-w-4xl mx-auto px-4 pb-16">
    <h2 class="text-2xl font-bold text-angel-text mb-6">❓ 자주 묻는 질문</h2>
    <div class="space-y-4">
      {faqItems.map((item) => (
        <details class="bg-angel-card border border-angel-border rounded-2xl p-5 group">
          <summary class="font-semibold text-angel-text cursor-pointer list-none flex items-center justify-between">
            {item.q}
            <span class="text-angel-muted group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-3 text-angel-muted text-sm leading-relaxed">{item.a}</p>
        </details>
      ))}
    </div>
  </section>
</Layout>
