---
import Layout from "../../layouts/Layout.astro";

const title = "엔젤넘버 가이드 - 천사의 숫자 메시지 완벽 안내";
const description = "엔젤넘버에 대해 알아야 할 모든 것. 엔젤넘버란 무엇인지, 어떻게 찾는지, 사랑과의 관계까지 상세히 안내합니다.";

const guides = [
  { slug: "what-is-angel-number", title: "엔젤넘버란 무엇인가?", description: "엔젤넘버의 기원, 수비학적 배경, 그리고 왜 특정 숫자가 반복적으로 보이는지 알아봅니다.", emoji: "👼" },
  { slug: "how-to-find-angel-number", title: "나만의 엔젤넘버 찾는 법", description: "생년월일, 이름, 일상 속 패턴을 통해 나에게 의미 있는 엔젤넘버를 발견하는 방법을 소개합니다.", emoji: "🔍" },
  { slug: "angel-number-and-love", title: "엔젤넘버와 사랑의 관계", description: "연애, 결혼, 이별, 재회 상황에서 엔젤넘버가 전하는 사랑의 메시지를 상세히 해석합니다.", emoji: "💕" },
];
---

<Layout title={title} description={description}>
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-angel-text mb-3 text-center">📖 엔젤넘버 가이드</h1>
    <p class="text-angel-muted text-center mb-10">엔젤넘버에 대해 더 깊이 알아보세요.</p>

    <div class="space-y-6">
      {guides.map((g) => (
        <a href={`/guide/${g.slug}`} class="block bg-angel-card border border-angel-border rounded-2xl p-6 hover:border-angel-primary/50 hover:shadow-lg hover:shadow-angel-glow transition-all group">
          <div class="flex items-start gap-4">
            <span class="text-3xl">{g.emoji}</span>
            <div>
              <h2 class="text-xl font-bold text-angel-text group-hover:text-angel-primary transition-colors mb-2">{g.title}</h2>
              <p class="text-angel-muted">{g.description}</p>
              <span class="text-sm text-angel-primary mt-2 inline-block">자세히 읽기 →</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
