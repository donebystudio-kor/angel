---
import Layout from "../layouts/Layout.astro";
import SearchBar from "../components/SearchBar.astro";
import { ANGEL_NUMBERS } from "../data/angels";

const numbersJson = JSON.stringify(ANGEL_NUMBERS.map(a => ({ number: a.number, summary: a.summary })));
---

<Layout title="엔젤넘버 검색 - 엔젤던" description="엔젤넘버를 검색하세요. 숫자의 의미와 메시지를 확인할 수 있습니다.">
  <section class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-2xl font-bold text-angel-text text-center mb-6">🔍 엔젤넘버 검색</h1>
    <SearchBar />

    <div id="search-page-results" class="mt-8"></div>
  </section>

  <script define:vars={{ numbersJson }}>
    const numbers = JSON.parse(numbersJson);
    const container = document.getElementById('search-page-results');
    const params = new URLSearchParams(window.location.search);
    const q = params.get('q')?.trim() || '';

    if (q) {
      const input = document.querySelector('.search-input');
      if (input) input.value = q;

      const matched = numbers.filter(n => n.number.includes(q) || n.summary.includes(q));

      if (matched.length === 0) {
        container.innerHTML = '<p class="text-center text-angel-muted">검색 결과가 없습니다.</p>';
      } else {
        container.innerHTML =
          `<p class="text-sm text-angel-muted mb-4">"${q}" 검색 결과 ${matched.length}개</p>` +
          '<div class="grid grid-cols-2 md:grid-cols-3 gap-3">' +
          matched.map(m =>
            `<a href="/number/${m.number}" class="bg-angel-card border border-angel-border rounded-xl p-4 hover:border-angel-primary/50 hover:shadow-lg hover:shadow-angel-glow transition-all">
              <div class="text-xl font-bold text-angel-primary">${m.number}</div>
              <div class="text-xs text-angel-muted mt-1 line-clamp-2">${m.summary}</div>
            </a>`
          ).join('') +
          '</div>';
      }
    } else {
      container.innerHTML = '<p class="text-center text-angel-muted">위 검색창에 숫자를 입력하고 엔터를 누르세요.</p>';
    }
  </script>
</Layout>
